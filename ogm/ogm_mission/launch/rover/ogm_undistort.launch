<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="use_sim_time" default="true" />
  <arg name="ns" default="ogm" />
  <arg name="pwd" default="$(dirname)" />
  <arg name="map_frame" default="map" />
  <arg name="map_odom_frame" default="livox_odom_galign" />
  <arg name="link_frame" default="base_link" />
  <arg name="odom_frame" default="livox_odom" />

  <node pkg="tf2_ros" exec="static_transform_publisher" name="sbr_gridmap_2_map"
    namespace="$(var ns)"
    output="log" 
    args="10.0 10.0 1.3
          0.0 0.0 0.0 1.0
          $(var map_frame) $(var map_odom_frame)">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="ogm_tools" exec="tf2odom" name="tf2odom_baselink"
    namespace="$(var ns)"
    output="log">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    
    <param name="map_frame" value="$(var map_frame)"/>
    <param name="target_frame" value="$(var link_frame)"/>
    <param name="use_tf_stamp" value="True"/>
    <param name="period" value="0.025"/>
  </node>

  <node pkg="ogm_tools" exec="tf2odom" name="tf2odom_pcd_projection"
    namespace="$(var ns)"
    output="log">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    
    <param name="map_frame" value="$(var map_frame)"/>
    <param name="target_frame" value="$(var map_odom_frame)"/>
    <param name="use_tf_stamp" value="False"/>
    <param name="period" value="0.025"/>
    
    <remap from="odom" to="pcd_projection_master_odom"/>
  </node>

  <node pkg="ogm_gridmap" exec="pcd_transformer" name="pcd_2_map"
    namespace="$(var ns)"
    output="log">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    
    <param name="odom_frame" value="$(var map_frame)"/>
    <param name="link_frame" value="$(var map_odom_frame)"/>
    <param name="target_frame" value="$(var odom_frame)"/>
    <param name="crop_haflplane_rear" value="-1e6"/>
    <param name="crop_haflplane_front" value="1e6"/>
    <param name="crop_haflplane_right" value="-1e6"/>
    <param name="crop_haflplane_left" value="1e6"/>
    <param name="sync_slack" value="1e6"/>
    <param name="sync_window" value="1.0"/>
      
    <remap from="pcd_in" to="/livox_odom/points_registered"/>
    <remap from="pcd_out" to="points_registered"/>
    <remap from="odom" to="pcd_projection_master_odom"/>
  </node>

  <node pkg="ogm_tools" exec="odom_cmd" name="odom_cmd"
    namespace="$(var ns)"
    output="log">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    
    <remap from="odom_in" to="odom"/>
    <remap from="odom_out" to="odom_cmd"/>
    <remap from="cmd" to="/controller_commands"/>
  </node>

  <node pkg="ogm_gridmap" exec="elevgrid" name="elevation_map"
    namespace="$(var ns)"
    output="log">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    
    <param name="map_frame" value="$(var map_frame)"/>
    <param name="do_pub_elevimg" value="True" />
    <param name="do_pub_occimg" value="False" />
    <param name="occgrid_vis_z" value="-0.5" />
    
    <param name="do_pub_elevgrid_real" value="True" />
    <param name="do_pub_elevgrid_vis" value="False" />
    
    <param name="cellsize" value="0.05" />
    <param name="height" value="20." />
    <param name="width" value="20." />
    <param name="discretize_elevimg" value="False" />
    <param name="elevimg_z_res" value="0.005" />
    <param name="clearance_thr" value="1." />
    <param name="do_clear_dir" value="true" />
    <param name="traversable_slope" value="0.78" />
      
    <remap from="pcd" to="points_registered"/>
    <remap from="clearance_odom" to="odom_cmd"/>
    <remap from="elevation_gridmap" to="elevation_gridmap_front"/>
    <remap from="elevation_img" to="elevation_img_front"/>
  </node>

  <node pkg="ogm_gridmap" exec="elevgrid" name="elevation_map"
    namespace="$(var ns)"
    output="log">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    
    <param name="map_frame" value="$(var map_frame)"/>
    <param name="do_pub_elevimg" value="True" />
    <param name="do_pub_occimg" value="False" />
    <param name="occgrid_vis_z" value="-0.5" />
    
    <param name="do_pub_elevgrid_real" value="True" />
    <param name="do_pub_elevgrid_vis" value="False" />
    
    <param name="cellsize" value="0.05" />
    <param name="height" value="20." />
    <param name="width" value="20." />
    <param name="discretize_elevimg" value="False" />
    <param name="elevimg_z_res" value="0.005" />
    <param name="clearance_thr" value="-1." />
    <param name="do_clear_dir" value="true" />
    <param name="traversable_slope" value="0.78" />
      
    <remap from="pcd" to="points_registered"/>
    <remap from="clearance_odom" to="odom_cmd"/>
    <remap from="elevation_gridmap" to="elevation_gridmap_rear"/>
    <remap from="elevation_img" to="elevation_img_rear"/>
  </node>

  <node pkg="ogm_gridmap" exec="rutmap" name="rutmap"
    namespace="$(var ns)"
    output="log">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    
    <param name="do_pub_exact" value="True" />
    <param name="do_pub_vis" value="True" />
    <param name="vis_scale" value="100.0" />
  </node>
    

</launch>
